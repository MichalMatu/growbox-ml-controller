{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Growbox Environment Controller Contract v2 (draft)",
  "schema_id": "environment-controller-v2",
  "schema_version": 2,
  "status": "draft",
  "io_status": "definitive",
  "sensing_status": "definitive",
  "draft_note": "Sensing + actuator slots DEFINITYWNE 2026-07. Full ML feature vector includes environment, global actuators, targets, previous, and per-zone cultivation/irrigation (103 features; firmware encoder will use 128-bit diagnostics mask). Not wired to production firmware yet.",
  "sensing_scope": {
    "physical_slots": 15,
    "pseudo_inputs": [
      "lights_active"
    ],
    "groups": {
      "air_inside": [
        "air_temperature_c",
        "air_humidity_pct",
        "co2_ppm"
      ],
      "nutrient_tank": [
        "nutrient_solution_temperature_c"
      ],
      "air_outside_intake": [
        "outside_temperature_c",
        "outside_humidity_pct",
        "outside_co2_ppm"
      ],
      "soil_per_zone": [
        "soil_moisture_zone_1_pct",
        "soil_temperature_zone_1_c",
        "soil_moisture_zone_2_pct",
        "soil_temperature_zone_2_c",
        "soil_moisture_zone_3_pct",
        "soil_temperature_zone_3_c",
        "soil_moisture_zone_4_pct",
        "soil_temperature_zone_4_c"
      ]
    },
    "explicitly_not_v2": [
      "ppfd_umol",
      "leaf_temperature_c",
      "ec_ms_cm",
      "ph",
      "flood_sensor",
      "exhaust_air_sensors",
      "weather_station"
    ]
  },
  "configuration_model": {
    "mix_and_match": true,
    "sensor_off": "validity.<slot> = false",
    "actuator_off": "actuators.<slot>.available = false",
    "zone_off": "zones[N].available = false",
    "no_required_bundles": true,
    "simulator_note": "Up to 4 zone slots; training scenarios randomize active count 0-4 and per-slot validity/irrigation \u2014 not always four pots."
  },
  "hash": {
    "algorithm": "sha256",
    "canonicalization": "UTF-8 JSON with lexicographically sorted keys and separators ',' and ':'",
    "short_hex_characters": 12
  },
  "groups": {
    "sensors": [
      "air_temperature_c",
      "air_humidity_pct",
      "co2_ppm",
      "nutrient_solution_temperature_c",
      "outside_temperature_c",
      "outside_humidity_pct",
      "outside_co2_ppm"
    ],
    "validity": [
      "air_temperature_valid",
      "air_humidity_valid",
      "co2_valid",
      "nutrient_solution_temperature_valid",
      "outside_temperature_valid",
      "outside_humidity_valid",
      "outside_co2_valid"
    ],
    "zones.0": [
